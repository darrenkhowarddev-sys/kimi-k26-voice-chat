OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=
HF_TOKEN=hf_...                 # used on the RunPod pod for Miso downloads, if needed

# Provider auto-selection (override with STT_PROVIDER / TTS_PROVIDER or CLI flags):
#   STT: elevenlabs (scribe) when ELEVENLABS_API_KEY is set, else openai (whisper-1)
#   TTS: miso when MISOTTS_ENDPOINT_URL is set, else elevenlabs, else openai
STT_PROVIDER=
TTS_PROVIDER=

MISOTTS_ENDPOINT_URL=https://your-runpod-proxy-url
MISOTTS_API_KEY=
MISOTTS_TIMEOUT_SECONDS=240

# OpenAI TTS tuning (optional)
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ElevenLabs tuning (optional)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STT_MODEL=scribe_v1
